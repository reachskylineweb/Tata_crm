# ============================================================
# TATA MOTORS CRM - BACKEND ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to Git.
# ============================================================

# ── SERVER ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
# Allowed values: development | production

# ── DATABASE ─────────────────────────────────────────────────
# Use DB_* prefix for ALL platforms (OVHcloud, DigitalOcean, Railway, local).
# Railway also injects MYSQLHOST etc. — those are handled as fallbacks in database.js.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_strong_password_here
DB_NAME=tatamotors_crm

# ── SECURITY ─────────────────────────────────────────────────
# REQUIRED — server will not start without this.
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Examples:
#   Vercel:       https://your-app.vercel.app
#   OVHcloud:     https://crm.yourdomain.com
#   DigitalOcean: https://crm.yourdomain.com
#   Multiple:     https://crm.yourdomain.com,https://your-app.vercel.app
CORS_ORIGIN=https://your-frontend-domain.com

# ── FILE UPLOADS ─────────────────────────────────────────────
# Relative directory for uploaded files (relative to backend root)
UPLOAD_DIR=uploads
