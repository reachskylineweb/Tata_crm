# ============================================================
# TATA MOTORS CRM - FRONTEND ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in your values.
# All VITE_ variables are embedded at build time.
# NEVER put secrets here — these values are visible in the browser bundle.
# ============================================================

# ── API URL ──────────────────────────────────────────────────
# Point to your backend API URL for each environment:
#
#   Local development : Leave VITE_API_URL unset (Vite proxy handles /api → localhost:3000)
#   Railway backend   : VITE_API_URL=https://tatacrm-production.up.railway.app/api
#   OVHcloud backend  : VITE_API_URL=https://api.yourdomain.com/api
#   DigitalOcean      : VITE_API_URL=https://api.yourdomain.com/api
#
VITE_API_URL=https://your-backend-domain.com/api
